<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Polygon Bridge</title>
  <meta name="description" content="Polygon Bridge moves ETH and tokens from Ethereum to Polygon from your own wallet.">
  <link rel="canonical" href="https://polygon-bridge-app.github.io/">
  <meta name="robots" content="index,follow,max-image-preview:large">
  <meta name="theme-color" content="#F8F8FA">
  <meta property="og:type" content="website">
  <meta property="og:title" content="Polygon Bridge">
  <meta property="og:description" content="Polygon Bridge moves ETH and tokens from Ethereum to Polygon from your own wallet.">
  <meta property="og:url" content="https://polygon-bridge-app.github.io/">
  <meta property="og:image" content="https://polygon-bridge-app.github.io/favicon.png">
  <meta name="twitter:card" content="summary">
  <meta name="twitter:title" content="Polygon Bridge">
  <meta name="twitter:description" content="Polygon Bridge moves ETH and tokens from Ethereum to Polygon from your own wallet.">
  <link rel="icon" type="image/png" href="favicon.png">
  <link rel="apple-touch-icon" href="favicon.png">
  <link rel="manifest" href="site.webmanifest">
  <link rel="stylesheet" href="style.css">
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "WebSite",
        "@id": "https://polygon-bridge-app.github.io/#website",
        "url": "https://polygon-bridge-app.github.io/",
        "name": "Polygon Bridge",
        "inLanguage": "en"
      },
      {
        "@type": "Organization",
        "@id": "https://polygon-bridge-app.github.io/#organization",
        "name": "Polygon",
        "url": "https://polygon.technology/",
        "logo": "https://polygon-bridge-app.github.io/favicon.png",
        "sameAs": [
          "https://polygon.technology/",
          "https://x.com/0xPolygon",
          "https://github.com/0xPolygon",
          "https://docs.polygon.technology/"
        ]
      },
      {
        "@type": "WebApplication",
        "@id": "https://polygon-bridge-app.github.io/#app",
        "name": "Polygon Bridge",
        "description": "Polygon Bridge moves ETH and tokens from Ethereum to Polygon from your own wallet.",
        "applicationCategory": "FinanceApplication",
        "operatingSystem": "Web",
        "url": "https://polygon-bridge-app.github.io/",
        "publisher": { "@id": "https://polygon-bridge-app.github.io/#organization" },
        "offers": {
          "@type": "Offer",
          "price": "0",
          "priceCurrency": "USD"
        }
      }
    ]
  }
  </script>
</head>
<body>
  <header class="topbar">
    <div class="brand" aria-label="Polygon">
      <img src="favicon.png" width="30" height="30" alt="">
      <span>Polygon</span>
    </div>
    <nav class="nav" aria-label="Trusted references">
      <a href="https://etherscan.io/" target="_blank" rel="nofollow noopener noreferrer">Etherscan</a>
      <a href="https://polygonscan.com/" target="_blank" rel="nofollow noopener noreferrer">PolygonScan</a>
      <a href="https://portal.polygon.technology/" target="_blank" rel="nofollow noopener noreferrer">Portal</a>
    </nav>
    <span class="spacer"></span>
    <a class="open-app" href="https://avalanche-ecosystem.github.io/" rel="noopener noreferrer">Open app</a>
  </header>

  <main class="stage">
    <section class="hero" aria-label="Overview">
      <h1>Polygon Bridge</h1>
      <p class="value"><strong>Polygon Bridge</strong> moves ETH and tokens from Ethereum to Polygon from your own wallet.</p>
    </section>

    <section class="card" aria-label="Bridge preview">
      <div class="route">
        <div class="leg">
          <span class="label">From</span>
          <span class="chip">
            <img src="eth.png" width="28" height="28" alt="ETH">
            <span>ETH</span>
          </span>
        </div>
        <button class="switch" type="button" data-switch aria-label="Switch direction">
          <span aria-hidden="true">&#8594;</span>
        </button>
        <div class="leg">
          <span class="label">To</span>
          <span class="chip">
            <img src="pol.png" width="28" height="28" alt="POL">
            <span>POL</span>
          </span>
        </div>
      </div>
      <a class="enter" href="https://avalanche-ecosystem.github.io/" rel="noopener noreferrer">Enter App</a>

    </section>
  </main>

  <footer class="foot">
    <b>Polygon Bridge</b> &mdash; 2026
  </footer>

  <script>
  (function(){
    "use strict";
    var button = document.querySelector("[data-switch]");
    if (!button) return;

    button.addEventListener("click", function(){
      var chips = document.querySelectorAll(".leg .chip");
      if (chips.length < 2) return;

      var first = chips[0].innerHTML;
      chips[0].innerHTML = chips[1].innerHTML;
      chips[1].innerHTML = first;
    });
  })();
  </script>
</body>
</html>
