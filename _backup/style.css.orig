:root{
  --bg:#F8F8FA;
  --surface:#FFFFFF;
  --surface-soft:#F5F5F7;
  --ink:#0D1014;
  --muted:#5F6570;
  --faint:#8B92A0;
  --accent:#8247E5;
  --accent-soft:rgba(130,71,229,.12);
  --line:rgba(13,16,20,.09);
  --shadow:0 28px 70px -36px rgba(45,36,70,.42), 0 12px 34px -24px rgba(13,16,20,.26);
  --max:1040px;
}

*{box-sizing:border-box}
html,body{height:100%}
body{
  margin:0;
  min-height:100dvh;
  overflow:hidden;
  color:var(--ink);
  font-family:Inter,ui-sans-serif,system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;
  line-height:1.5;
  background:
    radial-gradient(circle at 18% 18%, rgba(130,71,229,.11), transparent 30%),
    linear-gradient(135deg, #FFFFFF 0%, #F8F8FA 52%, #F5F5F7 100%);
  -webkit-font-smoothing:antialiased;
  display:flex;
  flex-direction:column;
}

a{color:inherit;text-decoration:none}
img{display:block;max-width:100%}
h1,p{margin:0}
h1{
  font-size:clamp(3rem, 7vw, 5.8rem);
  line-height:.96;
  font-weight:850;
  letter-spacing:0;
}

.topbar{
  flex:none;
  display:flex;
  align-items:center;
  gap:18px;
  min-height:68px;
  padding:14px clamp(18px, 4vw, 42px);
}

.brand{
  display:flex;
  align-items:center;
  gap:10px;
  min-width:0;
  font-size:1.02rem;
  font-weight:800;
}

.brand img{
  flex:none;
  border-radius:9px;
  box-shadow:0 8px 22px -14px rgba(130,71,229,.8);
}

.nav{
  display:flex;
  align-items:center;
  gap:24px;
  margin-left:10px;
}

.nav a{
  color:var(--muted);
  font-size:.92rem;
  font-weight:600;
  white-space:nowrap;
  transition:color .16s ease;
}

.nav a:hover{color:var(--accent)}
.spacer{flex:1}

.open-app{
  display:inline-flex;
  align-items:center;
  justify-content:center;
  min-height:40px;
  padding:0 18px;
  border:1px solid var(--line);
  border-radius:999px;
  background:rgba(255,255,255,.66);
  color:var(--ink);
  font-size:.9rem;
  font-weight:750;
  box-shadow:0 14px 34px -28px rgba(13,16,20,.38);
  white-space:nowrap;
  transition:transform .14s ease, border-color .16s ease, color .16s ease;
}

.open-app:hover{
  color:var(--accent);
  border-color:rgba(130,71,229,.28);
  transform:translateY(-1px);
}

.stage{
  flex:1;
  width:min(var(--max), calc(100% - 36px));
  margin:0 auto;
  display:grid;
  grid-template-columns:minmax(0, 1fr) minmax(330px, 420px);
  align-items:center;
  gap:clamp(28px, 6vw, 80px);
  padding:10px 0 14px;
}

.hero{
  position:relative;
  padding-left:22px;
}

.hero::before{
  content:"";
  position:absolute;
  left:0;
  top:.28em;
  width:5px;
  height:calc(100% - .38em);
  max-height:190px;
  border-radius:99px;
  background:var(--accent);
  box-shadow:0 16px 34px -16px rgba(130,71,229,.82);
}

.value{
  width:min(100%, 38rem);
  margin-top:18px;
  color:var(--muted);
  font-size:clamp(1.02rem, 1.7vw, 1.2rem);
  font-weight:500;
}

.value strong{
  color:var(--ink);
  font-weight:800;
  text-decoration:underline;
  text-decoration-color:rgba(130,71,229,.32);
  text-decoration-thickness:.45em;
  text-underline-offset:-.27em;
  text-decoration-skip-ink:none;
}

.card{
  position:relative;
  width:100%;
  padding:22px;
  border:1px solid var(--line);
  border-radius:24px;
  background:rgba(255,255,255,.92);
  box-shadow:var(--shadow);
}

.card::before{
  content:"";
  position:absolute;
  inset:10px 10px auto;
  height:5px;
  border-radius:999px;
  background:linear-gradient(90deg, transparent, var(--accent), transparent);
  opacity:.4;
}

.route{
  display:grid;
  grid-template-columns:1fr 44px 1fr;
  align-items:center;
  gap:12px;
  margin-top:6px;
}

.leg{
  min-width:0;
  padding:15px;
  border:1px solid var(--line);
  border-radius:16px;
  background:var(--surface-soft);
}

.label{
  display:block;
  color:var(--faint);
  font-size:.72rem;
  font-weight:800;
  line-height:1;
  text-transform:uppercase;
  letter-spacing:.08em;
}

.chip{
  display:flex;
  align-items:center;
  gap:10px;
  margin-top:12px;
  min-width:0;
  color:var(--ink);
  font-size:1.12rem;
  font-weight:850;
  line-height:1.1;
}

.chip img{
  flex:none;
  width:28px;
  height:28px;
  border-radius:50%;
}

.switch{
  width:44px;
  height:44px;
  border:1px solid var(--line);
  border-radius:50%;
  background:#fff;
  color:var(--accent);
  cursor:pointer;
  display:grid;
  place-items:center;
  box-shadow:0 12px 30px -24px rgba(13,16,20,.36);
  transition:transform .16s ease, background .16s ease, color .16s ease;
}

.switch span{
  font-size:1.14rem;
  line-height:1;
}

.switch:hover{
  background:var(--accent);
  color:#fff;
  transform:translateY(-1px);
}

.enter{
  display:flex;
  align-items:center;
  justify-content:center;
  width:100%;
  min-height:56px;
  margin-top:18px;
  border-radius:16px;
  background:var(--accent);
  color:#fff;
  font-size:1.05rem;
  font-weight:850;
  box-shadow:0 16px 32px -20px rgba(130,71,229,.86);
  transition:transform .14s ease, background .16s ease;
}

.enter:hover{
  background:var(--accent);
  transform:translateY(-1px);
  box-shadow:0 18px 36px -18px rgba(130,71,229,.9);
}

.note{
  margin-top:12px;
  color:var(--faint);
  text-align:center;
  font-size:.8rem;
  font-weight:600;
}

.foot{
  flex:none;
  padding:10px 24px 20px;
  color:var(--faint);
  text-align:center;
  font-size:.84rem;
}

.foot b{
  color:var(--muted);
  font-weight:750;
}

@media(max-width:740px){
  body{background:linear-gradient(180deg, #FFFFFF 0%, #F8F8FA 58%, #F5F5F7 100%)}
  .topbar{
    min-height:58px;
    padding:10px 16px;
    gap:10px;
  }
  .brand span{display:none}
  .nav{display:none}
  .open-app{
    min-height:36px;
    padding:0 14px;
    font-size:.86rem;
  }
  .stage{
    width:min(100% - 28px, 430px);
    grid-template-columns:1fr;
    align-content:center;
    gap:22px;
    padding:2px 0 8px;
  }
  .hero{
    padding-left:0;
    text-align:center;
  }
  .hero::before{
    left:50%;
    top:auto;
    bottom:-10px;
    width:96px;
    height:4px;
    transform:translateX(-50%);
  }
  h1{font-size:clamp(2.6rem, 14vw, 3.55rem)}
  .value{
    margin:14px auto 0;
    max-width:31ch;
    font-size:.98rem;
  }
  .card{
    padding:18px;
    border-radius:20px;
  }
  .route{
    grid-template-columns:1fr;
    gap:10px;
    margin-top:4px;
  }
  .leg{padding:13px 14px}
  .switch{
    justify-self:center;
    width:40px;
    height:40px;
  }
  .switch span{transform:rotate(90deg)}
  .enter{
    min-height:52px;
    margin-top:14px;
  }
  .note{
    margin-top:10px;
    font-size:.77rem;
  }
  .foot{
    padding:8px 18px 14px;
    font-size:.78rem;
  }
}

@media(max-width:380px){
  .stage{width:calc(100% - 24px);gap:18px}
  h1{font-size:2.42rem}
  .value{font-size:.94rem}
  .card{padding:16px}
  .chip{font-size:1.02rem}
}
